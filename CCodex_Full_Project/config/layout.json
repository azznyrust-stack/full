{
  "window_title_contains": "DeinSpiel",
  "rois": {
    "gold_text": {
      "x": 0.8,
      "y": 0.02,
      "w": 0.15,
      "h": 0.05
    },
    "loot_chat": {
      "x": 0.02,
      "y": 0.7,
      "w": 0.4,
      "h": 0.25
    },
    "dungeon_status": {
      "x": 0.35,
      "y": 0.02,
      "w": 0.3,
      "h": 0.06
    },
    "dungeon_counter": {
      "x": 0.9,
      "y": 0.1,
      "w": 0.08,
      "h": 0.05
    },
    "kill_counter": {
      "x": 0.9,
      "y": 0.16,
      "w": 0.08,
      "h": 0.05
    }
  },
  "parsing": {
    "loot_patterns": [
      "(?i)(?:du hast|ihr habt)\\s+(.+)\\s+(?:erhalten|gefunden)",
      "(?i)beute[:\\-]?\\s*(.+)",
      "(?i)(?:gegenstand|item) erhalten[:\\-]?\\s*(.+)"
    ],
    "loot_keywords": [
      "beute",
      "erhalten",
      "gefunden",
      "gegenstand"
    ],
    "dungeon_start_keywords": [
      "dungeon gestartet",
      "dungeon betreten",
      "betritt",
      "startet dungeon"
    ],
    "dungeon_end_keywords": [
      "dungeon abgeschlossen",
      "dungeon beendet",
      "verlassen",
      "abgeschlossen"
    ],
    "kill_patterns": [
      "(?i)(?:du|ihr)\\s*(?:hast|habt)?\\s*(?:besiegt|getötet)\\s+(.+)",
      "(?i)(.+) wurde besiegt"
    ],
    "kill_keywords": [
      "getötet",
      "besiegt",
      "erlegt"
    ]
  },
  "smoothing": {
    "median_window": 5,
    "stable_frames": 2,
    "event_cooldown_ms": 1500,
    "max_gold_jump": 5000000
  },
  "session": {
    "autosave_interval_s": 3,
    "sqlite_path": "output/farm.db"
  }
}
